   "source": [
    "n = 20\n",
    "\n",
    "# Final plot test for all benchmark\n",
    "plt.figure(figsize=(24, 16))\n",
    "for idx, row in metrics_df.iterrows():\n",
    "    key = row['benchmark']\n",
    "    # Get the base color for this benchmark from COLORS dictionary.\n",
    "    base_color = COLORS.get(key, \"#000000\")\n",
    "    \n",
    "    val_acc = eval(row['val_acc'])[:n]\n",
    "    val_recall = eval(row['val_recall'])[:n]\n",
    "\n",
    "    # Plot a scatter point for this benchmark.\n",
    "    plt.scatter(val_acc, val_recall,\n",
    "                color=base_color, s=100, alpha=0.3, edgecolor='k', label=key, marker='.')\n",
    "    \n",
    "    # Centroids\n",
    "    centroid_val_acc = np.mean(eval(row['val_acc']))\n",
    "    centroid_val_recall = np.mean(eval(row['val_recall']))\n",
    "    plt.scatter(centroid_val_acc, centroid_val_recall,\n",
    "                color=base_color, s=150, alpha=0.8, edgecolor='k', label=f\"{key} Ctrd\", marker='o')\n",
    "    \n",
    "    # Best epoch\n",
    "    best_epoch = row['last_saved_epoch']\n",
    "    best_val_acc = eval(row['val_acc'])[best_epoch]\n",
    "    best_val_recall = eval(row['val_recall'])[best_epoch]\n",
    "    plt.scatter(best_val_acc, best_val_recall,\n",
    "                color=base_color, s=400, alpha=1, edgecolor='k', label=f\"{key} Best\", marker='*')\n",
    "\n",
    "plt.xlabel(\"Validation Accuracy\")\n",
    "plt.ylabel(\"Validation Recall\")\n",
    "plt.title(\"Comparative Validation Metrics Across Benchmarks\")\n",
    "plt.legend(title=\"Benchmark\")\n",
    "plt.grid(True)\n",
    "plt.savefig('adversarial/models/devign/valid_acc_recall_all.png')\n",
    "plt.show()"
   ]
