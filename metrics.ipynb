   "source": [
    "# Define zoom limits\n",
    "x_min, x_max = 0.94, 0.985\n",
    "y_min, y_max = 0.94, 1.01\n",
    "\n",
    "plt.figure(figsize=(24, 16))\n",
    "\n",
    "for idx, row in metrics_df.iterrows():\n",
    "    key = row['benchmark']\n",
    "    base_color = COLORS.get(key, \"#000000\")\n",
    "    test_acc = row['test_acc']\n",
    "    test_recall = row['test_recall']\n",
    "\n",
    "    # Determine if it's an outlier\n",
    "    is_outlier = not (x_min <= test_acc <= x_max and y_min <= test_recall <= y_max)\n",
    "\n",
    "    # Adjust transparency for outliers\n",
    "    alpha_val = 0.2 if is_outlier else 1.0\n",
    "\n",
    "    # Plot the point\n",
    "    plt.scatter(test_acc, test_recall,\n",
    "                color=base_color, s=400, alpha=alpha_val,\n",
    "                edgecolor='k', label=key if not is_outlier else \"\", marker=\"*\")\n",
    "\n",
    "plt.xlabel(\"Test Accuracy\")\n",
    "plt.ylabel(\"Test Recall\")\n",
    "plt.title(\"Comparative Test Metrics Across Benchmarks\")\n",
    "plt.xlim(x_min, 1)\n",
    "plt.ylim(y_min, 1)\n",
    "plt.legend(title=\"Benchmark\")\n",
    "plt.grid(True)\n",
    "plt.savefig('adversarial/models/devign/test_all_focus.png')\n",
    "plt.show()"
   ]
  }
